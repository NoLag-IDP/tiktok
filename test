-- Animated loading dots
spawn(function()
	local loadingDots = 0
	while LoadingGui.Parent do
		loadingDots = (loadingDots + 1) % 4
		local dots = string.rep(".", loadingDots)
		LoadingText.Text = "Loading" .. dots
		task.wait(0.5)
	end
end)

-- Progress animation (6 minutes = 360 seconds) - STOPS AT 99%
spawn(function()
	local duration = 360
	local capProgress = 0.99
	local startTime = tick()

	while tick() - startTime < duration do
		local elapsed = tick() - startTime
		local progress = math.min(elapsed / duration, capProgress)

		ProgressFill.Size = UDim2.new(progress, 0, 1, 0)
		PercentText.Text = math.floor(progress * 100) .. "%"

		if progress >= capProgress then
			break
		end

		local pauseTime = math.random(30, 80) / 100
		task.wait(pauseTime)
	end

	-- Lock at 99% forever
	ProgressFill.Size = UDim2.new(0.99, 0, 1, 0)
	PercentText.Text = "99%"
	LoadingText.Text = "Almost there..."
end)
