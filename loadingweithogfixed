-- Dragging
local dragging = false
local dragInput = nil
local dragStart = nil
local startPos = nil

local function updateDrag(input)
    local delta = input.Position - dragStart
    LoadingFrame.Position = UDim2.new(
        startPos.X.Scale, startPos.X.Offset + delta.X,
        startPos.Y.Scale, startPos.Y.Offset + delta.Y
    )
end

LoadingFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = LoadingFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

LoadingFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        updateDrag(input)
    end
end)

-- Animated loading dots
task.spawn(function()
    local dots = 0
    while LoadingGui.Parent do
        dots = (dots + 1) % 4
        LoadingText.Text = "Loading" .. string.rep(".", dots)
        task.wait(0.5)
    end
end)

-- Progress bar animation
task.spawn(function()
    local duration = 195
    local startTime = tick()
    while tick() - startTime < duration do
        local elapsed = tick() - startTime
        local progress = math.min(elapsed / duration, 1)
        ProgressFill.Size = UDim2.new(progress, 0, 1, 0)
        PercentText.Text = math.floor(progress * 100) .. "%"
        task.wait(math.random(30, 80) / 100)
    end
    ProgressFill.Size = UDim2.new(1, 0, 1, 0)
    PercentText.Text = "100%"
    LoadingText.Text = "Complete!"
    task.wait(0.5)
    local tweens = {
        TweenService:Create(LoadingFrame, TweenInfo.new(0.5), {BackgroundTransparency = 1}),
        TweenService:Create(LoadingStroke, TweenInfo.new(0.5), {Transparency = 1}),
        TweenService:Create(LoadingTitle, TweenInfo.new(0.5), {TextTransparency = 1}),
        TweenService:Create(LoadingText, TweenInfo.new(0.5), {TextTransparency = 1}),
        TweenService:Create(PercentText, TweenInfo.new(0.5), {TextTransparency = 1}),
        TweenService:Create(SubText, TweenInfo.new(0.5), {TextTransparency = 1}),
        TweenService:Create(ProgressBg, TweenInfo.new(0.5), {BackgroundTransparency = 1}),
        TweenService:Create(ProgressFill, TweenInfo.new(0.5), {BackgroundTransparency = 1}),
    }
    for _, t in ipairs(tweens) do t:Play() end
    task.wait(0.6)
    LoadingGui:Destroy()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/NoLag-IDP/sablib/refs/heads/main/OGLB19"))()
end)
